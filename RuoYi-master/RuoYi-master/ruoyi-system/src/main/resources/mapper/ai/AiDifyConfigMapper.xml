<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.system.mapper.AiDifyConfigMapper">
    
    <resultMap type="AiDifyConfig" id="AiDifyConfigResult">
        <id     property="configId"       column="config_id"        />
        <result property="configName"     column="config_name"      />
        <result property="baseUrl"        column="base_url"         />
        <result property="apiKey"         column="api_key"          />
        <result property="configType"     column="config_type"      />
        <result property="isDefault"      column="is_default"       />
        <result property="status"         column="status"           />
        <result property="lastTestTime"   column="last_test_time"   />
        <result property="lastTestResult" column="last_test_result" />
        <result property="createBy"       column="create_by"        />
        <result property="createTime"     column="create_time"      />
        <result property="updateBy"       column="update_by"        />
        <result property="updateTime"     column="update_time"      />
        <result property="remark"         column="remark"           />
    </resultMap>

    <sql id="selectAiDifyConfigVo">
        select config_id, config_name, base_url, api_key, config_type, is_default, status, 
               last_test_time, last_test_result, create_by, create_time, update_by, update_time, remark 
        from ai_dify_config
    </sql>

    <select id="selectAiDifyConfigByConfigId" parameterType="Long" resultMap="AiDifyConfigResult">
        <include refid="selectAiDifyConfigVo"/>
        where config_id = #{configId}
    </select>

    <select id="selectAiDifyConfigList" parameterType="AiDifyConfig" resultMap="AiDifyConfigResult">
        <include refid="selectAiDifyConfigVo"/>
        <where>
            <if test="configName != null and configName != ''">
                AND config_name like concat('%', #{configName}, '%')
            </if>
            <if test="configType != null and configType != ''">
                AND config_type = #{configType}
            </if>
            <if test="status != null and status != ''">
                AND status = #{status}
            </if>
        </where>
        order by is_default desc, create_time desc
    </select>

    <select id="selectDefaultConfig" resultMap="AiDifyConfigResult">
        <include refid="selectAiDifyConfigVo"/>
        where is_default = 'Y' and status = '0'
        limit 1
    </select>

    <select id="selectDefaultConfigByType" parameterType="String" resultMap="AiDifyConfigResult">
        <include refid="selectAiDifyConfigVo"/>
        where config_type = #{configType} and status = '0'
        order by is_default desc, create_time desc
        limit 1
    </select>

    <insert id="insertAiDifyConfig" parameterType="AiDifyConfig" useGeneratedKeys="true" keyProperty="configId">
        insert into ai_dify_config
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="configName != null and configName != ''">config_name,</if>
            <if test="baseUrl != null and baseUrl != ''">base_url,</if>
            <if test="apiKey != null and apiKey != ''">api_key,</if>
            <if test="configType != null">config_type,</if>
            <if test="isDefault != null">is_default,</if>
            <if test="status != null">status,</if>
            <if test="createBy != null">create_by,</if>
            <if test="remark != null">remark,</if>
            create_time
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="configName != null and configName != ''">#{configName},</if>
            <if test="baseUrl != null and baseUrl != ''">#{baseUrl},</if>
            <if test="apiKey != null and apiKey != ''">#{apiKey},</if>
            <if test="configType != null">#{configType},</if>
            <if test="isDefault != null">#{isDefault},</if>
            <if test="status != null">#{status},</if>
            <if test="createBy != null">#{createBy},</if>
            <if test="remark != null">#{remark},</if>
            sysdate()
        </trim>
    </insert>

    <update id="updateAiDifyConfig" parameterType="AiDifyConfig">
        update ai_dify_config
        <trim prefix="SET" suffixOverrides=",">
            <if test="configName != null and configName != ''">config_name = #{configName},</if>
            <if test="baseUrl != null and baseUrl != ''">base_url = #{baseUrl},</if>
            <if test="apiKey != null and apiKey != ''">api_key = #{apiKey},</if>
            <if test="configType != null">config_type = #{configType},</if>
            <if test="isDefault != null">is_default = #{isDefault},</if>
            <if test="status != null">status = #{status},</if>
            <if test="lastTestTime != null">last_test_time = #{lastTestTime},</if>
            <if test="lastTestResult != null">last_test_result = #{lastTestResult},</if>
            <if test="updateBy != null">update_by = #{updateBy},</if>
            <if test="remark != null">remark = #{remark},</if>
            update_time = sysdate()
        </trim>
        where config_id = #{configId}
    </update>

    <delete id="deleteAiDifyConfigByConfigId" parameterType="Long">
        delete from ai_dify_config where config_id = #{configId}
    </delete>

    <delete id="deleteAiDifyConfigByConfigIds" parameterType="String">
        delete from ai_dify_config where config_id in 
        <foreach item="configId" collection="array" open="(" separator="," close=")">
            #{configId}
        </foreach>
    </delete>

    <update id="resetAllDefault">
        update ai_dify_config set is_default = 'N' where is_default = 'Y'
    </update>

</mapper>
