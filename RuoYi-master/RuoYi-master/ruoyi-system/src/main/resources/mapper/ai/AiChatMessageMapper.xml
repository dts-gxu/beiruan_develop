<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.system.mapper.AiChatMessageMapper">
    
    <resultMap type="AiChatMessage" id="AiChatMessageResult">
        <id     property="messageId"       column="message_id"        />
        <result property="conversationId"  column="conversation_id"   />
        <result property="role"            column="role"              />
        <result property="content"         column="content"           />
        <result property="contentType"     column="content_type"      />
        <result property="difyMessageId"   column="dify_message_id"   />
        <result property="modelName"       column="model_name"        />
        <result property="tokensUsed"      column="tokens_used"       />
        <result property="costTime"        column="cost_time"         />
        <result property="status"          column="status"            />
        <result property="createTime"      column="create_time"       />
    </resultMap>

    <sql id="selectAiChatMessageVo">
        select message_id, conversation_id, role, content, content_type, dify_message_id, 
               model_name, tokens_used, cost_time, status, create_time 
        from ai_chat_message
    </sql>

    <select id="selectAiChatMessageByMessageId" parameterType="Long" resultMap="AiChatMessageResult">
        <include refid="selectAiChatMessageVo"/>
        where message_id = #{messageId}
    </select>

    <select id="selectAiChatMessageList" parameterType="AiChatMessage" resultMap="AiChatMessageResult">
        <include refid="selectAiChatMessageVo"/>
        <where>
            <if test="conversationId != null">
                AND conversation_id = #{conversationId}
            </if>
            <if test="role != null and role != ''">
                AND role = #{role}
            </if>
            <if test="status != null and status != ''">
                AND status = #{status}
            </if>
        </where>
        order by create_time asc
    </select>

    <select id="selectMessagesByConversationId" parameterType="Long" resultMap="AiChatMessageResult">
        <include refid="selectAiChatMessageVo"/>
        where conversation_id = #{conversationId} and status = '0'
        order by create_time asc
    </select>

    <insert id="insertAiChatMessage" parameterType="AiChatMessage" useGeneratedKeys="true" keyProperty="messageId">
        insert into ai_chat_message
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="conversationId != null">conversation_id,</if>
            <if test="role != null">role,</if>
            <if test="content != null">content,</if>
            <if test="contentType != null">content_type,</if>
            <if test="difyMessageId != null">dify_message_id,</if>
            <if test="modelName != null">model_name,</if>
            <if test="tokensUsed != null">tokens_used,</if>
            <if test="costTime != null">cost_time,</if>
            <if test="status != null">status,</if>
            create_time
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="conversationId != null">#{conversationId},</if>
            <if test="role != null">#{role},</if>
            <if test="content != null">#{content},</if>
            <if test="contentType != null">#{contentType},</if>
            <if test="difyMessageId != null">#{difyMessageId},</if>
            <if test="modelName != null">#{modelName},</if>
            <if test="tokensUsed != null">#{tokensUsed},</if>
            <if test="costTime != null">#{costTime},</if>
            <if test="status != null">#{status},</if>
            sysdate()
        </trim>
    </insert>

    <update id="updateAiChatMessage" parameterType="AiChatMessage">
        update ai_chat_message
        <trim prefix="SET" suffixOverrides=",">
            <if test="content != null">content = #{content},</if>
            <if test="status != null">status = #{status},</if>
        </trim>
        where message_id = #{messageId}
    </update>

    <delete id="deleteAiChatMessageByMessageId" parameterType="Long">
        delete from ai_chat_message where message_id = #{messageId}
    </delete>

    <delete id="deleteAiChatMessageByMessageIds" parameterType="String">
        delete from ai_chat_message where message_id in 
        <foreach item="messageId" collection="array" open="(" separator="," close=")">
            #{messageId}
        </foreach>
    </delete>

    <delete id="deleteAiChatMessageByConversationId" parameterType="Long">
        delete from ai_chat_message where conversation_id = #{conversationId}
    </delete>

</mapper>
