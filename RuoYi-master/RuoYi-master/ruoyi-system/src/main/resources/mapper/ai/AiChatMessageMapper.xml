<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" 
    "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.system.mapper.AiChatMessageMapper">

    <resultMap type="com.ruoyi.system.domain.AiChatMessage" id="AiChatMessageResult">
        <result property="messageId"       column="message_id" />
        <result property="conversationId"  column="conversation_id" />
        <result property="role"            column="role" />
        <result property="content"         column="content" />
        <result property="contentType"     column="content_type" />
        <result property="tokensUsed"      column="tokens_used" />
        <result property="difyMessageId"   column="dify_message_id" />
        <result property="modelName"       column="model_name" />
        <result property="costTime"        column="cost_time" />
        <result property="status"          column="status" />
        <result property="createTime"      column="create_time" />
    </resultMap>

    <sql id="selectAiChatMessageVo">
        select message_id, conversation_id, role, content, content_type,
               tokens_used, dify_message_id, model_name, cost_time, status, create_time
        from ai_chat_message
    </sql>

    <select id="selectAiChatMessageByMessageId" parameterType="Long" resultMap="AiChatMessageResult">
        <include refid="selectAiChatMessageVo"/>
        where message_id = #{messageId}
    </select>

    <select id="selectAiChatMessageList" parameterType="com.ruoyi.system.domain.AiChatMessage" resultMap="AiChatMessageResult">
        <include refid="selectAiChatMessageVo"/>
        <where>
            <if test="conversationId != null">
                AND conversation_id = #{conversationId}
            </if>
            <if test="role != null and role != ''">
                AND role = #{role}
            </if>
            <if test="status != null and status != ''">
                AND status = #{status}
            </if>
        </where>
        order by create_time asc
    </select>

    <select id="selectMessagesByConversationId" parameterType="Long" resultMap="AiChatMessageResult">
        <include refid="selectAiChatMessageVo"/>
        where conversation_id = #{conversationId} and status = '0'
        order by create_time asc
    </select>

    <insert id="insertAiChatMessage" parameterType="com.ruoyi.system.domain.AiChatMessage" useGeneratedKeys="true" keyProperty="messageId">
        insert into ai_chat_message
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="conversationId != null">conversation_id,</if>
            <if test="role != null and role != ''">role,</if>
            <if test="content != null">content,</if>
            <if test="contentType != null and contentType != ''">content_type,</if>
            <if test="tokensUsed != null">tokens_used,</if>
            <if test="difyMessageId != null and difyMessageId != ''">dify_message_id,</if>
            <if test="modelName != null and modelName != ''">model_name,</if>
            <if test="costTime != null">cost_time,</if>
            <if test="status != null and status != ''">status,</if>
            create_time,
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="conversationId != null">#{conversationId},</if>
            <if test="role != null and role != ''">#{role},</if>
            <if test="content != null">#{content},</if>
            <if test="contentType != null and contentType != ''">#{contentType},</if>
            <if test="tokensUsed != null">#{tokensUsed},</if>
            <if test="difyMessageId != null and difyMessageId != ''">#{difyMessageId},</if>
            <if test="modelName != null and modelName != ''">#{modelName},</if>
            <if test="costTime != null">#{costTime},</if>
            <if test="status != null and status != ''">#{status},</if>
            sysdate(),
        </trim>
    </insert>

    <delete id="deleteAiChatMessageByMessageId" parameterType="Long">
        delete from ai_chat_message where message_id = #{messageId}
    </delete>

    <delete id="deleteAiChatMessageByConversationId" parameterType="Long">
        delete from ai_chat_message where conversation_id = #{conversationId}
    </delete>

</mapper>
