<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" 
    "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.system.mapper.AiDifyAppMapper">

    <resultMap type="com.ruoyi.system.domain.AiDifyApp" id="AiDifyAppResult">
        <result property="appId"        column="app_id" />
        <result property="configId"     column="config_id" />
        <result property="appName"      column="app_name" />
        <result property="appType"      column="app_type" />
        <result property="appApiKey"    column="app_api_key" />
        <result property="difyAppId"    column="dify_app_id" />
        <result property="workflowId"   column="workflow_id" />
        <result property="modelName"    column="model_name" />
        <result property="description"  column="description" />
        <result property="icon"         column="icon" />
        <result property="sortOrder"    column="sort_order" />
        <result property="status"       column="status" />
        <result property="delFlag"      column="del_flag" />
        <result property="createBy"     column="create_by" />
        <result property="createTime"   column="create_time" />
        <result property="updateBy"     column="update_by" />
        <result property="updateTime"   column="update_time" />
        <result property="remark"       column="remark" />
        <result property="configName"   column="config_name" />
        <result property="baseUrl"      column="base_url" />
    </resultMap>

    <sql id="selectAiDifyAppVo">
        select a.app_id, a.config_id, a.app_name, a.app_type, a.app_api_key,
               a.dify_app_id, a.workflow_id, a.model_name, a.description, a.icon,
               a.sort_order, a.status, a.del_flag,
               a.create_by, a.create_time, a.update_by, a.update_time, a.remark,
               c.config_name, c.base_url
        from ai_dify_app a
        left join ai_dify_config c on a.config_id = c.config_id
    </sql>

    <select id="selectAiDifyAppList" parameterType="com.ruoyi.system.domain.AiDifyApp" resultMap="AiDifyAppResult">
        <include refid="selectAiDifyAppVo"/>
        <where>
            a.del_flag = '0'
            <if test="appName != null and appName != ''">
                AND a.app_name like concat('%', #{appName}, '%')
            </if>
            <if test="appType != null and appType != ''">
                AND a.app_type = #{appType}
            </if>
            <if test="configId != null">
                AND a.config_id = #{configId}
            </if>
            <if test="status != null and status != ''">
                AND a.status = #{status}
            </if>
        </where>
        order by a.sort_order asc, a.create_time desc
    </select>

    <select id="selectAiDifyAppByAppId" parameterType="Long" resultMap="AiDifyAppResult">
        <include refid="selectAiDifyAppVo"/>
        where a.app_id = #{appId} and a.del_flag = '0'
    </select>

    <select id="selectActiveAppList" resultMap="AiDifyAppResult">
        <include refid="selectAiDifyAppVo"/>
        where a.status = '0' and a.del_flag = '0' and c.status = '0' and c.del_flag = '0'
        order by a.sort_order asc, a.create_time desc
    </select>

    <insert id="insertAiDifyApp" parameterType="com.ruoyi.system.domain.AiDifyApp" useGeneratedKeys="true" keyProperty="appId">
        insert into ai_dify_app
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="configId != null">config_id,</if>
            <if test="appName != null and appName != ''">app_name,</if>
            <if test="appType != null and appType != ''">app_type,</if>
            <if test="appApiKey != null and appApiKey != ''">app_api_key,</if>
            <if test="difyAppId != null and difyAppId != ''">dify_app_id,</if>
            <if test="workflowId != null and workflowId != ''">workflow_id,</if>
            <if test="modelName != null and modelName != ''">model_name,</if>
            <if test="description != null and description != ''">description,</if>
            <if test="icon != null and icon != ''">icon,</if>
            <if test="sortOrder != null">sort_order,</if>
            <if test="status != null and status != ''">status,</if>
            <if test="createBy != null and createBy != ''">create_by,</if>
            create_time,
            <if test="remark != null and remark != ''">remark,</if>
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="configId != null">#{configId},</if>
            <if test="appName != null and appName != ''">#{appName},</if>
            <if test="appType != null and appType != ''">#{appType},</if>
            <if test="appApiKey != null and appApiKey != ''">#{appApiKey},</if>
            <if test="difyAppId != null and difyAppId != ''">#{difyAppId},</if>
            <if test="workflowId != null and workflowId != ''">#{workflowId},</if>
            <if test="modelName != null and modelName != ''">#{modelName},</if>
            <if test="description != null and description != ''">#{description},</if>
            <if test="icon != null and icon != ''">#{icon},</if>
            <if test="sortOrder != null">#{sortOrder},</if>
            <if test="status != null and status != ''">#{status},</if>
            <if test="createBy != null and createBy != ''">#{createBy},</if>
            sysdate(),
            <if test="remark != null and remark != ''">#{remark},</if>
        </trim>
    </insert>

    <update id="updateAiDifyApp" parameterType="com.ruoyi.system.domain.AiDifyApp">
        update ai_dify_app
        <trim prefix="SET" suffixOverrides=",">
            <if test="configId != null">config_id = #{configId},</if>
            <if test="appName != null and appName != ''">app_name = #{appName},</if>
            <if test="appType != null and appType != ''">app_type = #{appType},</if>
            <if test="appApiKey != null and appApiKey != ''">app_api_key = #{appApiKey},</if>
            <if test="difyAppId != null">dify_app_id = #{difyAppId},</if>
            <if test="workflowId != null">workflow_id = #{workflowId},</if>
            <if test="modelName != null">model_name = #{modelName},</if>
            <if test="description != null">description = #{description},</if>
            <if test="icon != null">icon = #{icon},</if>
            <if test="sortOrder != null">sort_order = #{sortOrder},</if>
            <if test="status != null and status != ''">status = #{status},</if>
            <if test="updateBy != null and updateBy != ''">update_by = #{updateBy},</if>
            update_time = sysdate(),
            <if test="remark != null">remark = #{remark},</if>
        </trim>
        where app_id = #{appId}
    </update>

    <update id="deleteAiDifyAppByAppId" parameterType="Long">
        update ai_dify_app set del_flag = '2' where app_id = #{appId}
    </update>

    <update id="deleteAiDifyAppByAppIds" parameterType="String">
        update ai_dify_app set del_flag = '2' where app_id in
        <foreach item="appId" collection="array" open="(" separator="," close=")">
            #{appId}
        </foreach>
    </update>

</mapper>
