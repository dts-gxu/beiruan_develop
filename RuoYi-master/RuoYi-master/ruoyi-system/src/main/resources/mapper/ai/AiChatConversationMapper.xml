<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" 
    "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.system.mapper.AiChatConversationMapper">

    <resultMap type="com.ruoyi.system.domain.AiChatConversation" id="AiChatConversationResult">
        <result property="conversationId"     column="conversation_id" />
        <result property="appId"              column="app_id" />
        <result property="userId"             column="user_id" />
        <result property="difyConversationId" column="dify_conversation_id" />
        <result property="title"              column="title" />
        <result property="conversationType"   column="conversation_type" />
        <result property="status"             column="status" />
        <result property="messageCount"       column="message_count" />
        <result property="lastMessageTime"    column="last_message_time" />
        <result property="delFlag"            column="del_flag" />
        <result property="createBy"           column="create_by" />
        <result property="createTime"         column="create_time" />
        <result property="updateBy"           column="update_by" />
        <result property="updateTime"         column="update_time" />
        <result property="remark"             column="remark" />
        <result property="appName"            column="app_name" />
        <result property="userName"           column="user_name" />
    </resultMap>

    <sql id="selectAiChatConversationVo">
        select cv.conversation_id, cv.app_id, cv.user_id, cv.dify_conversation_id,
               cv.title, cv.conversation_type, cv.status, cv.message_count,
               cv.last_message_time, cv.del_flag,
               cv.create_by, cv.create_time, cv.update_by, cv.update_time, cv.remark,
               a.app_name, u.user_name
        from ai_chat_conversation cv
        left join ai_dify_app a on cv.app_id = a.app_id
        left join sys_user u on cv.user_id = u.user_id
    </sql>

    <select id="selectAiChatConversationList" parameterType="com.ruoyi.system.domain.AiChatConversation" resultMap="AiChatConversationResult">
        <include refid="selectAiChatConversationVo"/>
        <where>
            cv.del_flag = '0'
            <if test="appId != null">
                AND cv.app_id = #{appId}
            </if>
            <if test="userId != null">
                AND cv.user_id = #{userId}
            </if>
            <if test="title != null and title != ''">
                AND cv.title like concat('%', #{title}, '%')
            </if>
            <if test="conversationType != null and conversationType != ''">
                AND cv.conversation_type = #{conversationType}
            </if>
            <if test="status != null and status != ''">
                AND cv.status = #{status}
            </if>
        </where>
        order by cv.last_message_time desc, cv.create_time desc
    </select>

    <select id="selectAiChatConversationByConversationId" parameterType="Long" resultMap="AiChatConversationResult">
        <include refid="selectAiChatConversationVo"/>
        where cv.conversation_id = #{conversationId} and cv.del_flag = '0'
    </select>

    <insert id="insertAiChatConversation" parameterType="com.ruoyi.system.domain.AiChatConversation" useGeneratedKeys="true" keyProperty="conversationId">
        insert into ai_chat_conversation
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="appId != null">app_id,</if>
            <if test="userId != null">user_id,</if>
            <if test="difyConversationId != null and difyConversationId != ''">dify_conversation_id,</if>
            <if test="title != null and title != ''">title,</if>
            <if test="conversationType != null and conversationType != ''">conversation_type,</if>
            <if test="status != null and status != ''">status,</if>
            <if test="messageCount != null">message_count,</if>
            <if test="lastMessageTime != null">last_message_time,</if>
            <if test="createBy != null and createBy != ''">create_by,</if>
            create_time,
            <if test="remark != null and remark != ''">remark,</if>
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="appId != null">#{appId},</if>
            <if test="userId != null">#{userId},</if>
            <if test="difyConversationId != null and difyConversationId != ''">#{difyConversationId},</if>
            <if test="title != null and title != ''">#{title},</if>
            <if test="conversationType != null and conversationType != ''">#{conversationType},</if>
            <if test="status != null and status != ''">#{status},</if>
            <if test="messageCount != null">#{messageCount},</if>
            <if test="lastMessageTime != null">#{lastMessageTime},</if>
            <if test="createBy != null and createBy != ''">#{createBy},</if>
            sysdate(),
            <if test="remark != null and remark != ''">#{remark},</if>
        </trim>
    </insert>

    <update id="updateAiChatConversation" parameterType="com.ruoyi.system.domain.AiChatConversation">
        update ai_chat_conversation
        <trim prefix="SET" suffixOverrides=",">
            <if test="difyConversationId != null">dify_conversation_id = #{difyConversationId},</if>
            <if test="title != null and title != ''">title = #{title},</if>
            <if test="conversationType != null and conversationType != ''">conversation_type = #{conversationType},</if>
            <if test="status != null and status != ''">status = #{status},</if>
            <if test="messageCount != null">message_count = #{messageCount},</if>
            <if test="lastMessageTime != null">last_message_time = #{lastMessageTime},</if>
            <if test="updateBy != null and updateBy != ''">update_by = #{updateBy},</if>
            update_time = sysdate(),
            <if test="remark != null">remark = #{remark},</if>
        </trim>
        where conversation_id = #{conversationId}
    </update>

    <update id="deleteAiChatConversationByConversationId" parameterType="Long">
        update ai_chat_conversation set del_flag = '2' where conversation_id = #{conversationId}
    </update>

    <update id="deleteAiChatConversationByConversationIds" parameterType="String">
        update ai_chat_conversation set del_flag = '2' where conversation_id in
        <foreach item="conversationId" collection="array" open="(" separator="," close=")">
            #{conversationId}
        </foreach>
    </update>

</mapper>
